  (text "MIDI Out (optional)" (at 120.015 95.25 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 11867c5a-683a-4a4b-b44f-23ff756efc5f)
  )
  (text "Control scheme (\"simple_encoder\")" (at 120.015 138.43 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 14eda822-e7c1-4b90-8023-f3f31811a719)
  )
  (text "MIDI THRU (optional)" (at 226.06 34.925 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 2e4c32de-f562-43ec-b2d8-5990cf77e3fe)
  )
  (text "Power section" (at 27.305 138.43 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 3d4205d5-d1a1-4a6f-934d-f8f818f4277c)
  )
  (text "Connector for optional extras:" (at 160.02 233.045 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 4592bd98-898f-4a1d-88b6-3328b9c2af27)
  )
  (text "MIDI IN (optional)" (at 120.015 34.925 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 734c6b62-4a67-4e03-9816-d906c7d72251)
  )
  (text "5-pin connector for connecting up a rotary encoder such\nas the KY-040, note that we'll still need the SYNTH/ROM\nbuttons from the \"simple_buttons\" control scheme as\nwell. Currently the board does not have any proper\nmethods for mounting it, unless you're mounting the\nwhole thing in a separate case."
    (at 120.015 151.765 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 85bf7999-aa65-4e71-aa2b-cee1b75e29e1)
  )
  (text "Optional support for the extras board, \nduplicating most of the connectors not included on the\nmain board. \nIncludes RS232 as additional MIDI ports (note that these must be inverted in a \nseparate stage)."
    (at 146.05 244.475 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 9d85a90c-df14-4e58-9c49-75f14b62eb2d)
  )
  (text "Volume UP/DOWN is not needed when rotary encoder is\nused, some versions of faceplates may include SYNTH and\nVOL_UP and the duplicated switch should not be installed.\nJP3 is used to have the ROM switch replace VOL_UP."
    (at 182.88 147.32 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid a3e5d72f-e57f-447c-b8b2-734e511c6e29)
  )
  (text "RS-232 or TTL Serial USB adapter (optional)" (at 226.06 95.25 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid a449cbfb-8ec0-4efa-9db2-e515ca172c24)
  )
  (text "* Power LED resistor,\nsee description above." (at 298.45 182.88 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid ccc686a9-846f-44a1-8767-75586c893f93)
  )
  (text "OLED displays have unfortunately been produced with varying pinouts, we therefore need to add solder bridges to specify what the pins should\nbe connected to. Faceplate connector includes signals for both screen, control scheme pins as well as providing a power LED. When a modern\nLED of high efficiency is used, you should increase the value of R7 to something more suitable."
    (at 245.745 145.415 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid e5128ed4-61ab-48b5-8683-d23af4cbc3dc)
  )

